<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:id="@+id/tuningNameDisplay"
            android:text="Standard"
            android:textSize="22sp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/guitarTuningsButton"
            android:text="Guitar Tunings"
            android:layout_width="250dp"
            android:layout_height="60dp"/>

        <Button
            android:id="@+id/bassTuningsButton"
            android:text="Bass Tunings"
            android:layout_width="250dp"
            android:layout_height="60dp"/>

        <Button
            android:id="@+id/autoDetectButton"
            android:text="AUTO DETECT: ON"
            android:layout_width="250dp"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:id="@+id/noteDisplay"
            android:text="E"
            android:textSize="72sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/frequencyDisplay"
            android:text="82.41 Hz"
            android:textSize="24sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.example.intunainstrumenttuner.TunerMeterView
            android:id="@+id/tunerMeter"
            android:layout_width="300dp"
            android:layout_height="80dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/stringButtonsLayout"
                android:orientation="horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </HorizontalScrollView>

        <Button
            android:id="@+id/startStopButton"
            android:text="Start"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>
